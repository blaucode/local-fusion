# providers.env — provider API keys for local-fusion v2.
#
# Setup:  cp providers.env.example providers.env   then fill in your keys.
# providers.env is gitignored; NEVER commit real keys, never echo this file.
# Used by: `make spike-s1` (M1), `make docker-run` (M2+, --env-file).
# Env var names match v1 (orchestrator/run.py PROVIDERS) — the port contract.

# Featherless (https://featherless.ai → API Keys)
FEATHERLESS_API_KEY=

# Ollama Cloud (https://ollama.com → settings → API Keys)
OLLAMA_API_KEY=
